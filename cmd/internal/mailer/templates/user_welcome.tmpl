// Filename: internal/mailer/templates/user_welcome.tmpl


{{define "subject"}}Welcome to Lockit Appointments!{{end}}

{{define "plainBody"}}
Hi {{.username}},

Thanks for signing up for a Lockit Appointments account. We're excited to have you on board!

For future reference, your user ID number is {{.userID}}.

The following is your one time token to activate your account:

{{.activationToken}}

Please note that this is a one-time use token and it will expire in 3 days.

Thanks,
The Lockit Appointments Team
{{end}}

{{define "htmlBody"}}
<!doctype html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
</head>

<body>
    <p>Hi {{.username}},</p>
    <p>Thanks for signing up for a Lockit Appointments account. We're excited 
       to have you on board!</p>
    <p>For future reference, your user ID number is {{.userID}}.</p>
    <p>The following is your one time token to activate your account:</p>
    <pre><code>{{.activationToken}}</code></pre>
    <p>Please note that this is a one-time use token and it will 
       expire in 3 days.</p>

    <p>Thanks,</p>
    <p>The Lockit Appointments Team</p>
</body>

</html>
{{end}}
